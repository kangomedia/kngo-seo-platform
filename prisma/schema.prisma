generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth ─────────────────────────────────────────────

enum UserRole {
  AGENCY_ADMIN
  AGENCY_MEMBER
  CLIENT
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  hashedPassword String?
  image          String?
  role           UserRole  @default(CLIENT)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  clientAccess   ClientUser[]
  accounts       Account[]
  sessions       Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Clients ──────────────────────────────────────────

enum ClientTier {
  STARTER
  GROWTH
  PRO
}

model Client {
  id          String     @id @default(cuid())
  name        String
  domain      String?
  logoUrl     String?
  tier        ClientTier @default(STARTER)
  isActive    Boolean    @default(true)
  accessToken String     @unique @default(uuid())
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Contact / Business info
  contactName  String?
  contactEmail String?
  contactPhone String?
  address      String?
  city         String?
  state        String?
  zip          String?
  notes        String?

  // Google Business Profile
  gbpName      String?   // GBP listing name
  gbpUrl       String?   // GBP profile URL (maps.google.com link)
  gbpPhone     String?   // GBP phone number
  gbpAddress   String?   // GBP listed address
  gbpCategory  String?   // Primary GBP category

  // Deliverable template defaults (Local Visibility tier defaults)
  monthlyBlogs             Int @default(2)
  monthlyGbpPosts          Int @default(2)
  monthlyGbpQAs            Int @default(2)
  monthlyPressReleases     Int @default(1)
  monthlyDirectoryListings Int @default(25)
  includesAudit            Boolean @default(true)
  includesReporting        Boolean @default(true)

  // Google Integration
  gscProperty   String?  // GSC property URL (e.g. "sc-domain:example.com")
  ga4PropertyId String?  // GA4 property ID (e.g. "123456789")

  // Onboarding
  onboardingStatus  String?  @default("PENDING")  // PENDING, DISCOVERING, COMPLETE
  serviceAreas      String?  @db.Text              // JSON array: ["plumbing", "water heater repair"]
  targetCities      String?  @db.Text              // JSON array: ["McAllen, TX", "Mission, TX"]
  competitors       String?  @db.Text              // JSON array: ["competitor1.com", "competitor2.com"]

  // Relations
  users              ClientUser[]
  keywords           Keyword[]
  rankSnapshots      RankSnapshot[]
  contentPlans       ContentPlan[]
  deliverables       Deliverable[]
  reports            Report[]
  siteAudits         SiteAudit[]
  googleToken        GoogleToken?
  keywordResearch    KeywordResearch[]
  contentMaps        ContentMap[]
}

model ClientUser {
  id       String @id @default(cuid())
  userId   String
  clientId String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([userId, clientId])
}

// ─── Rankings ─────────────────────────────────────────

model Keyword {
  id           String   @id @default(cuid())
  clientId     String
  keyword      String
  searchVolume Int?
  difficulty   Int?
  targetUrl    String?
  group        String?  // keyword group/cluster name
  isTracking   Boolean  @default(true)
  createdAt    DateTime @default(now())

  client    Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  snapshots RankSnapshot[]

  @@unique([clientId, keyword])
}

model RankSnapshot {
  id          String   @id @default(cuid())
  clientId    String
  keywordId   String
  position    Int?     // null = not ranking
  previousPos Int?
  url         String?  // the URL that's ranking
  localPack   Boolean  @default(false)
  checkedAt   DateTime @default(now())

  client  Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  keyword Keyword @relation(fields: [keywordId], references: [id], onDelete: Cascade)

  @@index([clientId, checkedAt])
  @@index([keywordId, checkedAt])
}

// ─── Keyword Research ─────────────────────────────────

model KeywordResearch {
  id            String   @id @default(cuid())
  clientId      String
  seedTopics    String   @db.Text  // comma-separated seed topics used
  location      String   @default("United States")
  results       String   @db.Text  // JSON: array of discovered keywords with metrics + ROI
  aiAnalysis    String?  @db.Text  // Claude's strategic analysis and recommendations
  keywordsFound Int      @default(0)
  createdAt     DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, createdAt])
}

// ─── Content Maps ─────────────────────────────────────

model ContentMap {
  id         String   @id @default(cuid())
  clientId   String
  title      String   // e.g. "Q2 2026 Content Strategy"
  mapData    String   @db.Text  // JSON: pillar topics, supporting content, keyword clusters
  aiSummary  String?  @db.Text  // Claude's strategic summary
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

// ─── Content ──────────────────────────────────────────

enum ContentType {
  BLOG_POST
  GBP_POST
  GBP_QA
  PRESS_RELEASE
}

enum ContentStatus {
  PLANNED
  CLIENT_REVIEW
  APPROVED
  REJECTED
  WRITING
  DRAFT_REVIEW       // client reviewing final draft
  READY_TO_PUBLISH   // draft approved, awaiting publish
  PUBLISHED
  ARCHIVED
}

model ContentPlan {
  id          String   @id @default(cuid())
  clientId    String
  month       Int      // 1-12
  year        Int
  title       String   // e.g. "May 2026 Content Plan"
  seedKeyword String?
  planStatus  String   @default("DRAFT") // DRAFT, PENDING_APPROVAL, APPROVED, REJECTED
  planNotes   String?  @db.Text // Client feedback notes on plan
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  pieces ContentPiece[]

  @@unique([clientId, month, year])
}

model ContentPiece {
  id            String        @id @default(cuid())
  contentPlanId String
  type          ContentType
  title         String
  description   String?       @db.Text  // angle/brief
  keyword       String?       // target keyword
  body          String?       @db.Text  // full content body (markdown/html)
  status        ContentStatus @default(PLANNED)
  sortOrder     Int           @default(0)
  priority      Int           @default(0)  // higher = more urgent in queue
  revisionCount Int           @default(0)  // tracks revision cycles
  dueDate            DateTime?   // writing deadline
  scheduledPublishDate DateTime? // target publish date
  publishedUrl  String?
  publishedAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  contentPlan ContentPlan      @relation(fields: [contentPlanId], references: [id], onDelete: Cascade)
  approval    ContentApproval?
}

model ContentApproval {
  id             String   @id @default(cuid())
  contentPieceId String   @unique
  outcome        String   // 'approved', 'rejected', 'save_for_later'
  notes          String?  @db.Text
  imageUrl       String?  // reference photo from client
  decidedAt      DateTime @default(now())

  contentPiece ContentPiece @relation(fields: [contentPieceId], references: [id], onDelete: Cascade)
}

// ─── Deliverables ─────────────────────────────────────

enum DeliverableStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  OVERDUE
}

model Deliverable {
  id          String            @id @default(cuid())
  clientId    String
  month       Int
  year        Int
  name        String            // "Blog Posts", "GBP Posts", "Technical Audit", etc.
  targetCount Int               @default(1)
  currentCount Int              @default(0)
  status      DeliverableStatus @default(PENDING)
  notes       String?           @db.Text
  completedAt DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, month, year])
}

// ─── Reports ──────────────────────────────────────────

model Report {
  id          String   @id @default(cuid())
  clientId    String
  uuid        String   @unique @default(cuid()) // public share link
  month       Int
  year        Int
  title       String
  summary     String?  @db.Text // plain English summary
  highlights  String?  @db.Text // JSON array of key wins
  pdfUrl      String?
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, month, year])
}

// ─── Settings ─────────────────────────────────────────

model AgencySettings {
  id              String  @id @default("default")
  agencyName      String  @default("KangoMedia")
  logoUrl         String?
  dataforseoLogin String?
  dataforseoPwd   String?
  claudeApiKey    String?
  ghlApiKey       String?
  ghlLocationId   String?
}

// ─── Site Audit (On-Page SEO) ─────────────────────────

model SiteAudit {
  id          String   @id @default(cuid())
  clientId    String
  taskId      String?  // DataForSEO task ID
  status      String   @default("PENDING") // PENDING, CRAWLING, COMPLETED, FAILED
  pagesCount  Int      @default(0)
  onpageScore Float?   // 0-100 overall health score
  summary     String?  @db.Text // JSON: full crawl summary
  crawledAt   DateTime @default(now())

  client Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  pages  SiteAuditPage[]

  @@index([clientId, crawledAt])
}

model SiteAuditPage {
  id              String @id @default(cuid())
  auditId         String
  url             String
  statusCode      Int?
  title           String?
  description     String?  @db.Text
  h1Count         Int      @default(0)
  wordCount       Int      @default(0)
  imageCount      Int      @default(0)
  imagesNoAlt     Int      @default(0)
  checks          String?  @db.Text // JSON: per-page check results
  onpageScore     Float?
  recommendations String?  @db.Text // JSON: AI-generated recs per check

  audit  SiteAudit    @relation(fields: [auditId], references: [id], onDelete: Cascade)
  issues AuditIssue[]

  @@index([auditId])
}

model AuditIssue {
  id            String   @id @default(cuid())
  pageId        String
  checkKey      String   // e.g. "no_title", "title_too_long"
  severity      String   @default("warning") // "critical", "warning", "info"
  currentValue  String?  @db.Text // e.g. current title text
  suggestion    String?  @db.Text // AI-generated replacement
  status        String   @default("OPEN") // OPEN, FIXED, IGNORED
  fixedAt       DateTime?
  fixNotes      String?  @db.Text
  createdAt     DateTime @default(now())

  page SiteAuditPage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId])
  @@index([status])
}

// ─── Google Integration ───────────────────────────────

model GoogleToken {
  id           String   @id @default(cuid())
  clientId     String   @unique
  accessToken  String   @db.Text
  refreshToken String   @db.Text
  expiresAt    DateTime
  scope        String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
}
